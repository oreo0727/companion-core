# Companion Core local deployment example.
# Copy to .env for Docker Compose overrides, or export equivalent environment variables.

POSTGRES_DB=companion_core
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-for-shared-hosts

# Must be at least 32 characters. Never reuse the development value for an exposed instance.
JWT_SIGNING_KEY=replace-with-a-long-random-local-secret

# Use the host/IP that browsers and mobile devices can reach.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
COMPANION_WEB_BASE_URL=http://localhost:3000
